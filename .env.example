# App: Human-readable service name
APP_NAME=Grid Telemetry
# App: Backend version string
APP_VERSION=0.1.0
# App: Enable debug mode (true/false)
DEBUG=false
# App: Logging verbosity level
LOG_LEVEL=INFO

# Server: Bind host for FastAPI
HOST=0.0.0.0
# Server: Bind port for FastAPI
PORT=8000

# Redis: Connection URL for caching
REDIS_URL=redis://localhost:6379/0
# Redis: Cache time-to-live in seconds
REDIS_CACHE_TTL=2

# PostgreSQL: Async SQLAlchemy DSN
POSTGRES_DSN=postgresql+asyncpg://grid:telemetry@localhost:5432/grid_telemetry

# OpenF1: Base URL for API requests
OPENF1_BASE_URL=https://api.openf1.org/v1
# OpenF1: Session key ("latest" or explicit key)
OPENF1_SESSION_KEY=latest
# OpenF1: Poll interval in seconds
OPENF1_POLL_INTERVAL=0.27

# CORS: Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Frontend (Nuxt): Public backend HTTP base URL
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Frontend (Nuxt): Public backend websocket base URL
NUXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
